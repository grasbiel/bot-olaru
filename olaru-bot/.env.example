# --- Configuração Geral ---
# Se preenchido, o robô responderá APENAS a este número (formato: 5511999999999)
NUMERO_TESTE=

# --- Configurações do Chatwoot ---
CHATWOOT_URL=https://chatwoot.seu-dominio.com
CHATWOOT_BOT_TOKEN=seu-token-bot
ID_DA_CONTA=1

# --- Provedor de IA ---
# Opções: "groq" ou "gemini"
LLM_PROVIDER=groq
CHAVE_GROQ=gsk_xxx
GEMINI_API_KEY=

# --- Evolution API (Anti-Ban / Simulação de Presença) ---
EVOLUTION_WEBHOOK_SECRET=seu-segredo-webhook
EVOLUTION_API_URL=https://evolution.seu-dominio.com
EVOLUTION_API_KEY=sua-chave-api
EVOLUTION_INSTANCE=sua-instancia

# --- URL da API Java (Painel Administrativo) ---
JAVA_API_URL=http://api:8080/api/v1

# --- Banco de Dados PostgreSQL (RAG e Sessões) ---
DB_HOST=db
DB_NAME=db_construtora
DB_USER=postgres
DB_PASS=sua-senha
DB_PORT=5432

# --- Redis (Dedup, Rate Limit e Cache) ---
REDIS_HOST=db-redis
REDIS_PORT=6379
REDIS_PASS=
